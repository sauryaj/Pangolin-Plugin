$disableSsh = $cfg['DISABLE_SSH']       ?? '1';

// Read current daemon/interface state
$daemonRunning = \Newt\daemonRunning();
$interfaceUp   = \Newt\interfaceExists($interface);
$connected     = $daemonRunning && $interfaceUp;
?>

