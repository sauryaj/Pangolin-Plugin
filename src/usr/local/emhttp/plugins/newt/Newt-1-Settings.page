<script>
var newtCsrfToken = <?= json_encode((@parse_ini_file('/var/local/emhttp/var.ini') ?: [])['csrf_token'] ?? '') ?>;

function newtRefreshStatus() {
    $.post('/plugins/newt/include/action.php', { action: 'get-status', csrf_token: newtCsrfToken }, function(resp) {
        if (resp) {
            // Update logs
            $('#newt-logs').text(resp.logs || 'No logs available.');
            // Scroll to bottom of log container
            var logDiv = document.getElementById('newt-logs');
            logDiv.scrollTop = logDiv.scrollHeight;
        }
    }, 'json');
}

// Initial logs refresh and interval definition
newtRefreshStatus();
var newtInterval = setInterval(newtRefreshStatus, 5000);

function newtSaveSettings() {
    var form = document.getElementById('newt-settings-form');
    
    // Check form validation
    if (!form.checkValidity()) {
        form.reportValidity();
        return;
    }

    var data = {
        action:            'save',
        ENABLE_NEWT:       $('select[name=ENABLE_NEWT]', form).val(),
        PANGOLIN_ENDPOINT: $('input[name=PANGOLIN_ENDPOINT]', form).val(),
        NEWT_ID:           $('input[name=NEWT_ID]', form).val(),
        NEWT_SECRET:       $('input[name=NEWT_SECRET]', form).val(),
        INTERFACE:         $('input[name=INTERFACE]', form).val(),
        DNS:               $('input[name=DNS]', form).val(),
        MTU:               $('input[name=MTU]', form).val(),
        LOG_LEVEL:         $('select[name=LOG_LEVEL]', form).val(),
        DISABLE_SSH:       $('select[name=DISABLE_SSH]', form).val(),
        csrf_token:        newtCsrfToken
    };

    swal({
        title: 'Applying...',
        text: 'Applying configuration and connecting to Pangolin...',
        type: 'info',
        showConfirmButton: false
    });

    $.post('/plugins/newt/include/action.php', data, function(resp) {
        if (resp && resp.pending) {
            // Start polling status
            newtPollApply(resp.since || 0, 30);
        } else {
            swal({ title: 'Error', text: 'Unexpected response from server.', type: 'error' });
        }
    }, 'json').fail(function(xhr) {
        var errText = 'Request failed';
        if (xhr.responseJSON && xhr.responseJSON.error) {
            errText = xhr.responseJSON.error;
        } else if (xhr.responseText) {
            errText = xhr.responseText;
        }
        swal({ title: 'Error', text: errText, type: 'error' });
    });
}

function newtPollApply(since, triesLeft) {
    $.post('/plugins/newt/include/action.php', { action: 'apply-status', csrf_token: newtCsrfToken }, function(res) {
        var done = res && res.ts >= since && (res.ok === true || res.ok === false);
        if (done) {
            if (res.ok) {
                swal({ title: 'Connected!', text: res.message || 'Newt tunnel is active.', type: 'success', timer: 2000 });
            } else {
                swal({ title: 'Apply Failed', text: res.message || 'Could not connect to Pangolin.', type: 'error' });
            }
            setTimeout(function() { location.reload(); }, 2000);
            return;
        }
        if (triesLeft <= 0) {
            swal({ title: 'Still Connecting', text: 'Newt is still connecting in the background. Refreshing...', type: 'info' });
            setTimeout(function() { location.reload(); }, 2000);
            return;
        }
        setTimeout(function() { newtPollApply(since, triesLeft - 1); }, 1000);
    }, 'json').fail(function() {
        if (triesLeft <= 0) { location.reload(); return; }
        setTimeout(function() { newtPollApply(since, triesLeft - 1); }, 1000);
    });
}

function newtStopService() {
    swal({
        title: 'Stop Newt Service?',
        text: 'This will bring down the secure tunnel to Pangolin.',
        type: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#e74c3c',
        confirmButtonText: 'Stop',
        cancelButtonText: 'Cancel'
    }, function(confirmed) {
        if (confirmed) {
            swal({ title: 'Stopping...', text: 'Stopping daemon...', type: 'info', showConfirmButton: false });
            $.post('/plugins/newt/include/action.php', { action: 'stop', csrf_token: newtCsrfToken }, function(res) {
                if (res && res.success) {
                    swal({ title: 'Stopped', text: 'Newt service stopped.', type: 'success', timer: 1500 });
                } else {
                    swal({ title: 'Failed to Stop', text: res.message || 'Service could not be stopped.', type: 'error' });
                }
                setTimeout(function() { location.reload(); }, 1500);
            }, 'json').fail(function() {
                setTimeout(function() { location.reload(); }, 1500);
            });
        }
    });
}

// Clean interval on navigation away
window.addEventListener('beforeunload', function() {
    clearInterval(newtInterval);
});
</script>
<?php
} catch (\Throwable $e) {
    echo "<div style='background:#fee;padding:12px;border:1px solid #c00;border-radius:4px;'>"
       . "<b>Newt plugin error</b><pre>" . htmlspecialchars($e->getMessage() . "\n@ " . $e->getFile() . ':' . $e->getLine()) . "</pre></div>";
}
?>
